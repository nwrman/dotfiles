# ~/.secrets — Machine-local secrets (DO NOT COMMIT)
# Copy this file to ~/.secrets and fill in your values.
# This file is sourced by .zshrc if it exists.

export AWS_REGION="us-east-1"
export AWS_PROFILE="your-aws-profile"
export ANTHROPIC_MODEL="us.anthropic.claude-opus-4-6-v1"
export CLAUDE_CODE_USE_BEDROCK=1
export AZURE_DEVOPS_EXT_PAT="your-azure-devops-pat-here"
